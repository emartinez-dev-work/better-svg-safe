{
  "name": "better-svg",
  "displayName": "Better SVG",
  "description": "Preview your SVG with color picker, zoom controls, and SVGO optimization.",
  "version": "0.4.4",
  "publisher": "midudev",
  "author": {
    "name": "Miguel Ángel Durán",
    "email": "hi@midu.dev",
    "url": "https://midu.dev"
  },
  "pricing": "Free",
  "license": "Apache-2.0",
  "icon": "./static/icon.png",
  "galleryBanner": {
    "color": "#df6c31",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/midudev/better-svg"
  },
  "bugs": {
    "url": "https://github.com/midudev/better-svg/issues",
    "email": "hi@midu.dev"
  },
  "homepage": "https://github.com/midudev/better-svg#readme",
  "qna": "marketplace",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18.15.0"
  },
  "activationEvents": [
    "onLanguage:svg",
    "onLanguage:xml",
    "onLanguage:astro",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "onLanguage:svelte",
    "onLanguage:vue",
    "onLanguage:django-html",
    "onLanguage:liquid"
  ],
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "svg",
    "svg-preview",
    "svg-editor",
    "svg-optimization",
    "svgo",
    "vector-graphics",
    "graphics",
    "visualization",
    "preview",
    "optimize"
  ],
  "main": "./dist/extension.js",
  "files": [
    "static/icon.png",
    "dist/webview",
    "dist/extension.js",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "contributes": {
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "betterSvg.preview",
          "name": "SVG Preview",
          "icon": "$(eye)",
          "when": "betterSvg.hasSvgOpen"
        }
      ]
    },
    "languages": [
      {
        "id": "liquid",
        "aliases": [
          "Liquid"
        ],
        "extensions": [
          ".liquid"
        ]
      }
    ],
    "commands": [
      {
        "command": "betterSvg.optimize",
        "title": "Optimize SVG",
        "category": "Better SVG",
        "icon": "$(zap)"
      },
      {
        "command": "betterSvg.optimizeFromHover",
        "title": "Optimize SVG from Hover",
        "category": "Better SVG",
        "icon": "$(zap)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "betterSvg.optimize",
          "when": "editorTextFocus && resourceExtname == .svg"
        }
      ],
      "editor/title": [
        {
          "command": "betterSvg.optimize",
          "when": "resourceExtname == .svg",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Better SVG",
      "properties": {
        "betterSvg.autoReveal": {
          "type": "boolean",
          "default": true,
          "description": "Automatically reveal and expand the SVG Preview panel in Explorer when opening SVG files"
        },
        "betterSvg.autoCollapse": {
          "type": "boolean",
          "default": true,
          "description": "Automatically collapse the SVG Preview panel in Explorer when closing all SVG files"
        },
        "betterSvg.defaultColor": {
          "type": "string",
          "default": "#ffffff",
          "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$",
          "description": "Default color for currentColor in the SVG preview (hex format, e.g., #ffffff)"
        },
        "betterSvg.removeClasses": {
          "type": "boolean",
          "default": true,
          "description": "Remove class attributes from SVG elements during optimization"
        },
        "betterSvg.enableHover": {
          "type": "boolean",
          "default": true,
          "description": "Enable hover preview for SVG elements in supported files"
        },
        "betterSvg.showGutterPreview": {
          "type": "boolean",
          "default": true,
          "description": "Show SVG preview icons next to line numbers in supported files"
        }
      }
    },
    "configurationDefaults": {
      "workbench.editorAssociations": {
        "*.svg": "default"
      }
    }
  },
  "scripts": {
    "pnpm": "pnpm",
    "vscode:prepublish": "pnpm package",
    "compile": "pnpm check-types && node esbuild.js && pnpm copy-webview",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "watch:webview": "node -e \"require('fs').watch('src/webview', () => require('child_process').exec('pnpm copy-webview'))\"",
    "package": "pnpm check-types && node esbuild.js --production && pnpm copy-webview",
    "check-types": "tsc --noEmit",
    "copy-webview": "mkdir -p dist/webview && cp src/webview/*.html src/webview/*.css src/webview/*.js dist/webview/",
    "test": "node --import tsx --test src/*.test.ts",
    "test:vscode": "vscode-test",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "^18.15.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "esbuild": "0.27.3",
    "eslint": "9.39.4",
    "neostandard": "0.13.0",
    "npm-run-all": "4.1.5",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "svgo": "4.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
